@model IEnumerable<GunDammvc.Models.Order>
@{
    ViewData["Title"] = "Quản Lý Đơn Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .table-luxury th {
        border-bottom: 2px solid var(--border-color);
        color: var(--text-secondary);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.85rem;
        padding-bottom: 15px;
    }
    .table-luxury td {
        border-bottom: 1px solid var(--border-color);
        vertical-align: middle;
        padding: 20px 0;
    }
    .status-select {
        border: 1px solid var(--border-color);
        border-radius: 2px;
        padding: 8px 12px;
        font-size: 0.85rem;
        background: #fafafa;
        transition: 0.3s;
        cursor: pointer;
    }
    .status-select:focus {
        border-color: var(--luxury-gold);
        box-shadow: none;
        outline: none;
        background: #fff;
    }
</style>

<div class="container py-5 fade-in-up">
    <h2 class="font-serif mb-5 text-center text-uppercase" style="letter-spacing: 2px;">Quản Lý Đơn Hàng</h2>

    <!-- Thanh điều hướng Admin -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="Dashboard" class="btn btn-outline-luxury py-2 px-3 me-2">Xem Dashboard</a>
            <a asp-action="Index" class="btn btn-outline-luxury py-2 px-3">Quản Lý Sản Phẩm</a>
        </div>
    </div>

    <div class="bg-white p-5 border shadow-sm" style="border-radius: 2px;">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-luxury mb-0">
                    <thead>
                        <tr>
                            <th>Mã Đơn</th>
                            <th>Khách Hàng</th>
                            <th>Ngày Đặt</th>
                            <th>Tổng Tiền</th>
                            <th>Trạng Thái Hiện Tại</th>
                            <th class="text-end">Cập Nhật Trạng Thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@order.OrderId</td>
                                <td>
                                    <div class="fw-bold">@order.FirstName @order.LastName</div>
                                    <small class="text-muted">@order.PhoneNumber</small>
                                </td>
                                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-bold" style="color: var(--luxury-gold);">
                                    @order.OrderTotal.ToString("N0") đ
                                </td>
                                <td>
                                    @if (order.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark rounded-1 fw-normal px-2 py-1">Chờ Xử Lý</span>
                                    }
                                    else if (order.Status == "Paid")
                                    {
                                        <span class="badge bg-info text-dark rounded-1 fw-normal px-2 py-1">Đã Thanh Toán</span>
                                    }
                                    else if (order.Status == "Shipped")
                                    {
                                        <span class="badge bg-primary rounded-1 fw-normal px-2 py-1">Đang Giao Hàng</span>
                                    }
                                    else if (order.Status == "Cancelled")
                                    {
                                        <span class="badge bg-danger rounded-1 fw-normal px-2 py-1">Đã Hủy</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <form asp-controller="Admin" asp-action="UpdateOrderStatus" method="post" class="d-flex justify-content-end align-items-center gap-2">
                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                        <select name="newStatus" class="form-select status-select w-auto shadow-none">
                                            <option value="Pending" selected="@(order.Status == "Pending")">Chờ Xử Lý</option>
                                            <option value="Paid" selected="@(order.Status == "Paid")">Đã Thanh Toán</option>
                                            <option value="Shipped" selected="@(order.Status == "Shipped")">Đang Giao Hàng</option>
                                            <option value="Cancelled" selected="@(order.Status == "Cancelled")">Đã Hủy</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-luxury px-3">Lưu</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-muted mb-3" style="font-size: 3rem;"></i>
                <p class="text-muted fs-5">Chưa có đơn hàng nào trong hệ thống.</p>
            </div>
        }
    </div>
</div>