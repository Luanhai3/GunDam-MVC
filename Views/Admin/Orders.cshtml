@model IEnumerable<GunDammvc.Models.Order>
@{
    ViewData["Title"] = "Quản Lý Đơn Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .table-luxury th {
        border-bottom: 2px solid var(--border-color);
        color: var(--text-secondary);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.85rem;
        padding-bottom: 15px;
    }
    .table-luxury td {
        border-bottom: 1px solid var(--border-color);
        vertical-align: middle;
        padding: 20px 0;
    }
    .status-select {
        border: 1px solid var(--border-color);
        border-radius: 2px;
        padding: 8px 12px;
        font-size: 0.85rem;
        background: #fafafa;
        transition: 0.3s;
        cursor: pointer;
    }
    .status-select:focus {
        border-color: var(--luxury-gold);
        box-shadow: none;
        outline: none;
        background: #fff;
    }
</style>

<div class="container py-5 fade-in-up">
    <h2 class="font-serif mb-5 text-center text-uppercase" style="letter-spacing: 2px;">Quản Lý Đơn Hàng</h2>

    <!-- Thanh điều hướng Admin -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <a asp-action="Dashboard" class="btn btn-outline-luxury py-2 px-3 me-2">Xem Dashboard</a>
            <a asp-action="Index" class="btn btn-outline-luxury py-2 px-3 me-2">Quản Lý Sản Phẩm</a>
            <a asp-action="Users" class="btn btn-outline-luxury py-2 px-3">Quản Lý Người Dùng</a>
        </div>
        <form method="get" class="d-flex align-items-center flex-wrap gap-3">
            <div class="d-flex align-items-center">
                <div class="input-group" style="width: 250px;">
                    <input type="text" name="searchQuery" value="@ViewBag.SearchQuery" class="form-control shadow-none border-0 px-2" style="border-bottom: 1px solid var(--luxury-gold) !important; border-radius: 0; background: transparent; font-size: 0.9rem;" placeholder="Mã đơn, SĐT, Tên..." />
                    @if (!string.IsNullOrEmpty(ViewBag.SearchQuery) || !string.IsNullOrEmpty(ViewBag.PaymentMethod) || !string.IsNullOrEmpty(ViewBag.Status))
                    {
                        <a asp-action="Orders" class="btn border-0 shadow-none px-2 text-danger" style="border-bottom: 1px solid var(--luxury-gold) !important; border-radius: 0; background: transparent;" title="Xóa bộ lọc"><i class="bi bi-x-lg"></i></a>
                    }
                    <button type="submit" class="btn border-0 shadow-none px-2 text-muted" style="border-bottom: 1px solid var(--luxury-gold) !important; border-radius: 0; background: transparent;"><i class="bi bi-search"></i></button>
                </div>
            </div>

            <div class="d-flex align-items-center">
                <label class="me-2 text-muted fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 1px;">Thanh Toán:</label>
                <select name="paymentMethod" class="form-select shadow-none border-0" style="border-bottom: 1px solid var(--luxury-gold) !important; border-radius: 0; width: 140px; font-weight: 500;" onchange="this.form.submit()">
                    <option value="">Tất cả</option>
                    <option value="COD" selected="@(ViewBag.PaymentMethod == "COD")">COD</option>
                    <option value="BankTransfer" selected="@(ViewBag.PaymentMethod == "BankTransfer")">Chuyển Khoản</option>
                    <option value="VNPay" selected="@(ViewBag.PaymentMethod == "VNPay")">VNPay</option>
                </select>
            </div>
            <div class="d-flex align-items-center">
                <label class="me-2 text-muted fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 1px;">Trạng Thái:</label>
                <select name="status" class="form-select shadow-none border-0" style="border-bottom: 1px solid var(--luxury-gold) !important; border-radius: 0; width: 160px; font-weight: 500;" onchange="this.form.submit()">
                    <option value="">Tất cả</option>
                    <option value="Pending" selected="@(ViewBag.Status == "Pending")">Chờ Xử Lý</option>
                    <option value="Paid" selected="@(ViewBag.Status == "Paid")">Đã Thanh Toán</option>
                    <option value="Shipped" selected="@(ViewBag.Status == "Shipped")">Đang Giao Hàng</option>
                    <option value="Completed" selected="@(ViewBag.Status == "Completed")">Giao Thành Công</option>
                    <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Đã Hủy</option>
                </select>
            </div>
        </form>
    </div>

    <div class="bg-white p-5 border shadow-sm" style="border-radius: 2px;">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-luxury mb-0">
                    <thead>
                        <tr>
                            <th>Mã Đơn</th>
                            <th>Khách Hàng</th>
                            <th>Ngày Đặt</th>
                            <th>Tổng Tiền</th>
                            <th>Thanh Toán</th>
                            <th>Trạng Thái Hiện Tại</th>
                            <th class="text-end">Cập Nhật Trạng Thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@order.OrderId</td>
                                <td>
                                    <div class="fw-bold">@order.FirstName @order.LastName</div>
                                    <small class="text-muted">@order.PhoneNumber</small>
                                </td>
                                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-bold" style="color: var(--luxury-gold);">
                                    @order.OrderTotal.ToString("N0") đ
                                </td>
                                <td>
                                    @if (order.PaymentMethodSelection == GunDammvc.Models.PaymentMethod.BankTransfer)
                                    {
                                        <span class="badge bg-light text-dark border"><i class="bi bi-bank me-1"></i> Chuyển Khoản</span>
                                    }
                                    else if (order.PaymentMethodSelection == GunDammvc.Models.PaymentMethod.VNPay)
                                    {
                                        <span class="badge bg-light text-primary border"><i class="bi bi-credit-card me-1"></i> VNPay</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-secondary border"><i class="bi bi-cash me-1"></i> COD</span>
                                    }
                                </td>
                                <td>
                                    @if (order.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark rounded-1 fw-normal px-2 py-1">Chờ Xử Lý</span>
                                    }
                                    else if (order.Status == "Paid")
                                    {
                                        <span class="badge bg-info text-dark rounded-1 fw-normal px-2 py-1">Đã Thanh Toán</span>
                                    }
                                    else if (order.Status == "Shipped")
                                    {
                                        <span class="badge bg-primary rounded-1 fw-normal px-2 py-1">Đang Giao Hàng</span>
                                    }
                                    else if (order.Status == "Cancelled")
                                    {
                                        <span class="badge bg-danger rounded-1 fw-normal px-2 py-1">Đã Hủy</span>
                                    }
                                    else if (order.Status == "Completed")
                                    {
                                        <span class="badge bg-success rounded-1 fw-normal px-2 py-1">Giao Hàng Thành Công</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-1 fw-normal px-2 py-1">@order.Status</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <form asp-controller="Admin" asp-action="UpdateOrderStatusAjax" method="post" class="d-flex justify-content-end align-items-center gap-2" onsubmit="updateStatusAjax(event, this)">
                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                        <select name="newStatus" class="form-select status-select w-auto shadow-none">
                                            <option value="Pending" selected="@(order.Status == "Pending")">Chờ Xử Lý</option>
                                            <option value="Paid" selected="@(order.Status == "Paid")">Đã Thanh Toán</option>
                                            <option value="Shipped" selected="@(order.Status == "Shipped")">Đang Giao Hàng</option>
                                            <option value="Completed" selected="@(order.Status == "Completed")">Giao Hàng Thành Công</option>
                                            <option value="Cancelled" selected="@(order.Status == "Cancelled")">Đã Hủy</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-luxury px-3">Lưu</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Phân Trang (Pagination) -->
            <nav class="mt-4 pt-3 border-top fade-in-up">
                <ul class="pagination justify-content-center mb-0">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link text-dark shadow-none" href="?page=@(ViewBag.CurrentPage - 1)&paymentMethod=@ViewBag.PaymentMethod&status=@ViewBag.Status&searchQuery=@ViewBag.SearchQuery">Trang Trước</a>
                        </li>
                    }
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link @(i == ViewBag.CurrentPage ? "bg-dark border-dark text-white" : "text-dark") shadow-none" href="?page=@i&paymentMethod=@ViewBag.PaymentMethod&status=@ViewBag.Status&searchQuery=@ViewBag.SearchQuery">@i</a>
                        </li>
                    }
                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link text-dark shadow-none" href="?page=@(ViewBag.CurrentPage + 1)&paymentMethod=@ViewBag.PaymentMethod&status=@ViewBag.Status&searchQuery=@ViewBag.SearchQuery">Trang Sau</a>
                        </li>
                    }
                </ul>
            </nav>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-muted mb-3" style="font-size: 3rem;"></i>
                <p class="text-muted fs-5">Chưa có đơn hàng nào trong hệ thống.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function updateStatusAjax(event, form) {
            event.preventDefault();
            if (!confirm('Bạn có chắc chắn muốn cập nhật trạng thái đơn hàng này?')) return;

            // Lưu trạng thái nút và bật hiệu ứng loading
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalBtnContent = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';

            const formData = new FormData(form);
            const newStatus = formData.get('newStatus');

            fetch(form.action, {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                // Khôi phục lại nút
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnContent;

                if (data.success) {
                    toastr.success(data.message);
                    
                    const tr = form.closest('tr');
                    const badge = tr.querySelector('td:nth-child(5) .badge');
                    
                    if (badge) {
                        badge.className = 'badge rounded-1 fw-normal px-2 py-1'; // Reset class
                        if (newStatus === "Pending") { badge.classList.add('bg-warning', 'text-dark'); badge.innerText = 'Chờ Xử Lý'; }
                        else if (newStatus === "Paid") { badge.classList.add('bg-info', 'text-dark'); badge.innerText = 'Đã Thanh Toán'; }
                        else if (newStatus === "Shipped") { badge.classList.add('bg-primary'); badge.innerText = 'Đang Giao Hàng'; }
                        else if (newStatus === "Completed") { badge.classList.add('bg-success'); badge.innerText = 'Giao Hàng Thành Công'; }
                        else if (newStatus === "Cancelled") { badge.classList.add('bg-danger'); badge.innerText = 'Đã Hủy'; }
                    }
                } else {
                    toastr.error(data.message || 'Có lỗi xảy ra.');
                }
            })
            .catch(err => {
                // Khôi phục lại nút khi có lỗi
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnContent;

                toastr.error('Lỗi kết nối tới máy chủ.');
                console.error(err);
            });
        }
    </script>
}