@model GunDammvc.Models.Product
@{
    ViewData["Title"] = "Thêm Sản Phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 fade-in-up">
    <h2 class="mb-4 font-serif">Thêm Sản Phẩm Mới</h2>
    <div class="card shadow-sm p-4 border-0" style="border-radius: 2px;">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="form-label text-muted small text-uppercase" style="letter-spacing: 1px;"></label>
                    <input asp-for="Name" class="form-control shadow-none rounded-0" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Grade" class="form-label text-muted small text-uppercase" style="letter-spacing: 1px;"></label>
                    <input asp-for="Grade" class="form-control shadow-none rounded-0" placeholder="VD: HG, MG, RG..." />
                    <span asp-validation-for="Grade" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="form-label text-muted small text-uppercase" style="letter-spacing: 1px;"></label>
                    <input asp-for="Price" class="form-control shadow-none rounded-0" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Stock" class="form-label text-muted small text-uppercase" style="letter-spacing: 1px;"></label>
                    <input asp-for="Stock" class="form-control shadow-none rounded-0" />
                    <span asp-validation-for="Stock" class="text-danger"></span>
                </div>
                <div class="col-12 mb-3">
                    <label class="form-label text-muted small text-uppercase" style="letter-spacing: 1px;">Ảnh Sản Phẩm (Tải lên)</label>
                    <input type="file" name="imageFile" class="form-control shadow-none rounded-0" accept="image/*" />
                    <small class="text-muted">Định dạng hỗ trợ: JPG, PNG, WEBP.</small>
                </div>
                <div class="col-12 mb-4">
                    <label asp-for="Description" class="form-label text-muted small text-uppercase" style="letter-spacing: 1px;"></label>
                    <textarea asp-for="Description" class="form-control shadow-none rounded-0" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-luxury px-4">Lưu Sản Phẩm</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2 rounded-0">Hủy</a>
            </div>
        </form>
    </div>
</div>