@model GunDammvc.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<div class="container my-5">
    <h2 class="font-serif mb-4">Edit Product</h2>

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold"></label>
                    <input asp-for="Name" class="form-control luxury-input" required />
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Grade" class="form-label fw-bold"></label>
                        <select asp-for="Grade" class="form-select luxury-select">
                            <option value="HG">HG</option>
                            <option value="RG">RG</option>
                            <option value="MG">MG</option>
                            <option value="PG">PG</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label fw-bold"></label>
                        <input asp-for="Price" class="form-control luxury-input" type="number" required />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Stock" class="form-label fw-bold"></label>
                        <input asp-for="Stock" class="form-control luxury-input" type="number" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ImageUrl" class="form-label fw-bold">Image URL</label>
                        <input asp-for="ImageUrl" class="form-control luxury-input" />
                    </div>
                </div>
                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold"></label>
                    <textarea asp-for="Description" class="form-control luxury-input" rows="5"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-luxury px-4">Save Changes</button>
                    <a asp-action="Index" class="btn btn-outline-dark rounded-0 px-4 py-2">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>