@model GunDammvc.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container my-5">
    <h2 class="font-serif text-danger mb-4">Delete Product</h2>
    
    <div class="alert alert-warning rounded-0 border-0 mb-4 bg-opacity-10 text-dark">
        Are you sure you want to delete <strong>@Model.Name</strong>? This action cannot be undone.
    </div>

    <div class="card border-0 bg-light p-4 mb-4" style="max-width: 600px;">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-muted">Name</dt>
            <dd class="col-sm-9 fw-bold">@Model.Name</dd>

            <dt class="col-sm-3 text-muted">Grade</dt>
            <dd class="col-sm-9">@Model.Grade</dd>

            <dt class="col-sm-3 text-muted">Price</dt>
            <dd class="col-sm-9">@Model.Price.ToString("N0") VNĐ</dd>

            <dt class="col-sm-3 text-muted">Stock</dt>
            <dd class="col-sm-9">@Model.Stock</dd>
        </dl>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger rounded-0 px-4 py-2 text-uppercase letter-spacing-1">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-outline-dark rounded-0 px-4 py-2 text-uppercase letter-spacing-1">Cancel</a>
        </div>
    </form>
</div>