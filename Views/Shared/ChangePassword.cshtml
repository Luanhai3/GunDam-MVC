@page
@{
    ViewData["Title"] = "Change Password";
}

<h4 class="font-serif mb-4">@ViewData["Title"]</h4>

<div class="card border-0 bg-transparent">
    <div class="card-body p-0">
        <form asp-controller="Account" asp-action="ChangePassword" method="post" class="w-100" style="max-width: 600px;">

            <div class="mb-4">
                <label for="OldPassword" class="form-label text-uppercase letter-spacing-1 small fw-bold text-muted">Mật Khẩu Hiện Tại</label>
                <input id="OldPassword" name="OldPassword" type="password" class="form-control luxury-input py-3" required />
            </div>

            <div class="mb-4">
                <label for="NewPassword" class="form-label text-uppercase letter-spacing-1 small fw-bold text-muted">Mật Khẩu Mới</label>
                <input id="NewPassword" name="NewPassword" type="password" class="form-control luxury-input py-3" required />
            </div>

            <div class="mb-4">
                <label for="ConfirmPassword" class="form-label text-uppercase letter-spacing-1 small fw-bold text-muted">Xác Nhận Mật Khẩu Mới</label>
                <input id="ConfirmPassword" name="ConfirmPassword" type="password" class="form-control luxury-input py-3" required />
            </div>

            <div class="mt-5">
                <button type="submit" class="btn btn-luxury py-3 px-5 fs-6 letter-spacing-1">Thay Đổi Mật Khẩu</button>
            </div>
        </form>
    </div>
</div>