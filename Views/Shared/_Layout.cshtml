@using Microsoft.AspNetCore.Identity
@using GunDammvc.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject IShoppingCartService ShoppingCartService
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GUNDAM MVC</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GunDammvc.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #FDFBF7;
            --text-primary: #1A1A1A;
            --text-secondary: #555555;
            --luxury-gold: #B89B5E;
            --border-color: #EAE8E3;
        }
        body {
            background-color: var(--bg-color) !important;
            color: var(--text-primary);
            font-family: 'Jost', sans-serif;
        }
        h1, h2, h3, h4, h5, h6, .font-serif, .serif {
            font-family: 'Playfair Display', serif;
        }
        .btn-luxury {
            background-color: var(--text-primary);
            color: #fff;
            border: 1px solid var(--text-primary);
            padding: 12px 24px;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.85rem;
            border-radius: 2px;
        }
        .btn-luxury:hover {
            background-color: var(--luxury-gold);
            border-color: var(--luxury-gold);
            color: #fff;
        }
        .btn-outline-luxury {
            background-color: transparent;
            color: var(--text-primary);
            border: 1px solid var(--text-primary);
            padding: 12px 24px;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.85rem;
            border-radius: 2px;
        }
        .btn-outline-luxury:hover {
            background-color: var(--text-primary);
            color: #fff;
        }
        .fade-in-up {
            animation: fadeInUp 0.8s ease forwards;
        }
       @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .navbar {
            background-color: rgba(255, 255, 255, 0.95) !important;
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color);
            padding: 20px 0;
            transition: all 0.4s ease-in-out;
        }
        .navbar.navbar-scrolled {
            padding: 10px 0;
            box-shadow: 0 4px 25px rgba(0,0,0,0.08);
            border-bottom-color: transparent;
        }
        .nav-link {
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-size: 0.85rem;
            color: var(--text-primary) !important;
            transition: all 0.3s ease;
            position: relative;
            padding: 0.5rem 1rem !important;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: 0;
            left: 50%;
            background-color: var(--luxury-gold);
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            transform: translateX(-50%);
        }
        .nav-link:hover::after,
        .nav-item.dropdown:hover .nav-link::after {
            width: 70%;
        }
        .nav-link:hover {
            color: var(--luxury-gold) !important;
        }
        .cart-anim::after { display: none; } /* Tắt gạch chân cho nút giỏ hàng */
        .cart-anim {
            transition: transform 0.3s ease;
        }
        .cart-anim:hover {
            transform: scale(1.1) rotate(-5deg);
            color: var(--luxury-gold) !important;
        }
        /* Dropdown Menu Animations */
        .dropdown-menu {
            border: none;
            border-radius: 4px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
            animation: dropdownFade 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }
        @@keyframes dropdownFade {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .dropdown-item {
            transition: all 0.2s ease;
        }
        .dropdown-item:hover {
            background-color: transparent;
            color: var(--luxury-gold) !important;
            padding-left: 1.5rem;
        }
        .footer-luxury {
            background-color: #0a0a0a;
            color: #b0b0b0;
            border-top: 2px solid var(--luxury-gold);
            position: relative;
            overflow: hidden;
        }
        .footer-luxury::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(circle at 50% 0%, rgba(184, 155, 94, 0.15), transparent 70%);
            pointer-events: none;
        }
        .footer-link {
            color: #888;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-block;
        }
        .footer-link:hover {
            color: var(--luxury-gold);
            transform: translateX(8px);
        }
        .social-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: rgba(255,255,255,0.05);
            color: #fff;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            text-decoration: none;
        }
        .social-icon:hover {
            background-color: var(--luxury-gold);
            color: #fff;
            transform: translateY(-5px) rotate(8deg);
            box-shadow: 0 10px 20px rgba(184, 155, 94, 0.3);
        }
        /* Back to Top Button */
        .back-to-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 45px;
            height: 45px;
            background-color: var(--luxury-gold);
            color: #fff;
            border: none;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
            z-index: 999;
            cursor: pointer;
            transform: translateY(20px);
        }
        .back-to-top.show {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }
        /* Giữ Menu Đăng nhập/Tài khoản luôn trên 1 hàng ngang */
        .auth-actions .navbar-nav {
            flex-direction: row !important;
            align-items: center;
            gap: 0.5rem;
        }
        .auth-actions .nav-item {
            white-space: nowrap;
            display: flex;
            align-items: center;
        }
        .auth-actions button.nav-link {
            border: none;
            background: transparent;
        }
        .auth-actions form {
            margin-bottom: 0;
            display: flex;
            align-items: center;
        }
        /* Ẩn mũi tên tăng/giảm mặc định của thẻ input type="number" */
        input[type="number"]::-webkit-outer-spin-button,
        input[type="number"]::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        input[type="number"] {
            -moz-appearance: textfield;
        }
        .back-to-top:hover {
            background-color: var(--text-primary);
            transform: translateY(-5px);
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand font-serif fs-4" asp-controller="Home" asp-action="Index" style="letter-spacing: 2px;">GUNDAM MVC</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang Chủ</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Shop" asp-action="Index">Cửa Hàng</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">Giới Thiệu</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Contact" asp-action="Index">Liên Hệ</a></li>
                        @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Quản Trị Admin</a>
                                <ul class="dropdown-menu shadow-sm border" aria-labelledby="adminDropdown" style="border-radius: 2px; border-color: var(--border-color) !important;">
                                    <li><a class="dropdown-item py-2 text-uppercase small text-muted" style="letter-spacing: 1px;" asp-controller="Admin" asp-action="Dashboard">Dashboard Thống Kê</a></li>
                                    <li><a class="dropdown-item py-2 text-uppercase small text-muted" style="letter-spacing: 1px;" asp-controller="Admin" asp-action="Index">Quản Lý Sản Phẩm</a></li>
                                    <li><a class="dropdown-item py-2 text-uppercase small text-muted fw-bold text-dark" style="letter-spacing: 1px;" asp-controller="Admin" asp-action="Orders">Quản Lý Đơn Hàng</a></li>
                                    <li><a class="dropdown-item py-2 text-uppercase small text-muted" style="letter-spacing: 1px;" asp-controller="Admin" asp-action="Users">Quản Lý Người Dùng</a></li>
                                    <li><a class="dropdown-item py-2 text-uppercase small text-muted" style="letter-spacing: 1px;" asp-controller="Admin" asp-action="Reviews">Quản Lý Đánh Giá</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center auth-actions">
                        <partial name="_LoginPartial" />
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <a href="#offcanvasCart" data-bs-toggle="offcanvas" role="button" aria-controls="offcanvasCart" class="nav-link ms-2 position-relative cart-anim">
                                <i class="bi bi-cart-fill fs-4"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    @(await ShoppingCartService.GetCartItemCountAsync(User))
                                </span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer-luxury pt-5 pb-4 mt-5">
        <div class="container text-center text-md-start">
            <div class="row text-center text-md-start">
                <div class="col-md-4 col-lg-4 col-xl-4 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4 font-serif fs-4" style="color: var(--luxury-gold); letter-spacing: 1px;">GunDam MVC</h5>
                    <p>Cửa hàng mô hình Gundam chính hãng, mang đến những sản phẩm chất lượng cao cho người hâm mộ và nhà sưu tập.</p>
                </div>

                <div class="col-md-2 col-lg-2 col-xl-2 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4" style="color: var(--luxury-gold); font-size: 0.9rem; letter-spacing: 1px;">Dòng Sản Phẩm</h5>
                    <p><a asp-controller="Home" asp-action="Index" asp-route-grade="HG" class="footer-link">HG - High Grade</a></p>
                    <p><a asp-controller="Home" asp-action="Index" asp-route-grade="RG" class="footer-link">RG - Real Grade</a></p>
                    <p><a asp-controller="Home" asp-action="Index" asp-route-grade="MG" class="footer-link">MG - Master Grade</a></p>
                    <p><a asp-controller="Home" asp-action="Index" asp-route-grade="PG" class="footer-link">PG - Perfect Grade</a></p>
                </div>

                <div class="col-md-3 col-lg-2 col-xl-2 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4" style="color: var(--luxury-gold); font-size: 0.9rem; letter-spacing: 1px;">Liên Kết Hữu Ích</h5>
                    <p><a asp-controller="Home" asp-action="Index" class="footer-link">Trang Chủ</a></p>
                    <p><a asp-controller="Shop" asp-action="Index" class="footer-link">Cửa Hàng</a></p>
                    <p><a asp-controller="Admin" asp-action="Index" class="footer-link">Quản Trị</a></p>
                    <p><a asp-controller="Home" asp-action="Privacy" class="footer-link">Chính Sách Bảo Mật</a></p>
                </div>

                <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4" style="color: var(--luxury-gold); font-size: 0.9rem; letter-spacing: 1px;">Liên hệ</h5>
                    <p><i class="bi bi-geo-alt-fill me-3 text-white-50"></i>Quận 1, TP. Hồ Chí Minh, Việt Nam</p>
                    <p><i class="bi bi-envelope-fill me-3 text-white-50"></i>hotro@gundammvc.com</p>
                    <p><i class="bi bi-telephone-fill me-3 text-white-50"></i>+84 123 456 789</p>
                </div>
            </div>

            <hr class="mb-4" style="border-color: #333;">

            <div class="d-flex justify-content-between align-items-center flex-column flex-md-row">
                <p class="mb-2 mb-md-0" style="font-size: 0.9rem;"> &copy; @DateTime.UtcNow.Year - GunDam MVC | Design by Louis Hoang</p>
                <div class="text-center">
                    <a href="#" class="social-icon me-2"><i class="bi bi-facebook fs-5"></i></a>
                    <a href="#" class="social-icon me-2"><i class="bi bi-twitter fs-5"></i></a>
                    <a href="#" class="social-icon me-2"><i class="bi bi-instagram fs-5"></i></a>
                    <a href="#" class="social-icon"><i class="bi bi-youtube fs-5"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Offcanvas Mini Cart -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasCart" aria-labelledby="offcanvasCartLabel">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title font-serif fw-bold" id="offcanvasCartLabel">Giỏ Hàng</h5>
            <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0" id="miniCartBody">
            <!-- Content will be loaded here via AJAX -->
        </div>
    </div>

    <!-- Modal Quy tắc thăng hạng -->
    <div class="modal fade" id="tierModal" tabindex="-1" aria-labelledby="tierModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 4px;">
          <div class="modal-header border-bottom-0 pb-0 px-4 pt-4">
            <h5 class="modal-title font-serif fw-bold" id="tierModalLabel" style="color: var(--luxury-gold); letter-spacing: 1px;">Đặc Quyền Thành Viên</h5>
            <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body p-4 pt-3">
            <p class="text-muted small mb-3">Hạng thành viên được xét duyệt dựa trên <strong>tổng điểm tích lũy trọn đời</strong> của bạn. Việc sử dụng điểm để thanh toán đơn hàng sẽ <strong>không</strong> làm ảnh hưởng đến thứ hạng này.</p>
            <div class="alert alert-light border mb-4 p-3" style="border-radius: 4px;">
                <h6 class="fw-bold mb-2" style="font-size: 0.9rem; color: var(--text-primary);"><i class="bi bi-info-circle me-2"></i>Quy tắc tích điểm & sử dụng:</h6>
                <ul class="mb-0 small text-muted ps-3" style="line-height: 1.6;">
                    <li class="mb-1"><strong>Tích điểm:</strong> Mỗi <strong>20.000 VNĐ</strong> thanh toán thành công = <strong>1 Điểm</strong>.</li>
                    <li><strong>Sử dụng:</strong> Quy đổi <strong>1 Điểm</strong> = <strong>1.000 VNĐ</strong> giảm giá cho đơn hàng.</li>
                </ul>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-award" style="font-size: 1.8rem; color: #CD7F32;"></i>
                        <div>
                            <strong style="color: #CD7F32; font-size: 1.1rem;">Thành Viên Đồng</strong>
                            <div class="small text-muted mt-1">Dưới 500 điểm</div>
                        </div>
                    </div>
                    <span class="badge bg-light text-dark border px-3 py-2">Tích điểm</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-award-fill" style="font-size: 1.8rem; color: #9e9e9e;"></i>
                        <div>
                            <strong style="color: #9e9e9e; font-size: 1.1rem;">Thành Viên Bạc</strong>
                            <div class="small text-muted mt-1">500 - 1.999 điểm</div>
                        </div>
                    </div>
                    <span class="badge px-3 py-2" style="background-color: #C0C0C0; color: #000;">Giảm 2%</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-trophy-fill" style="font-size: 1.8rem; color: #d4af37;"></i>
                        <div>
                            <strong style="color: #d4af37; font-size: 1.1rem;">Thành Viên Vàng</strong>
                            <div class="small text-muted mt-1">Từ 2.000 điểm trở lên</div>
                        </div>
                    </div>
                    <span class="badge bg-warning text-dark px-3 py-2">Giảm 5%</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-gem" style="font-size: 1.8rem; color: #00ced1;"></i>
                        <div>
                            <strong style="color: #00ced1; font-size: 1.1rem;">Thành Viên Kim Cương</strong>
                            <div class="small text-muted mt-1">Từ 5.000 điểm trở lên</div>
                        </div>
                    </div>
                    <span class="badge text-dark px-3 py-2" style="background-color: #E0FFFF;">Giảm 10%</span>
                </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Nút Back to Top -->
    <button id="backToTop" class="back-to-top" title="Lên đầu trang">
        <i class="bi bi-arrow-up"></i>
    </button>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (TempData["SuccessMessage"] != null)
    {
        <script type="text/javascript">
            toastr.success('@TempData["SuccessMessage"]');
        </script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script type="text/javascript">
            toastr.error("@TempData["ErrorMessage"]");
        </script>
    }
    @if (TempData["WarningMessage"] != null)
    {
        <script type="text/javascript">
            toastr.warning("@TempData["WarningMessage"]");
        </script>
    }

    <!-- Script tải dữ liệu Mini Cart -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var offcanvasElement = document.getElementById('offcanvasCart');
            if (offcanvasElement) {
                offcanvasElement.addEventListener('show.bs.offcanvas', function () {
                    $('#miniCartBody').html('<div class="d-flex justify-content-center mt-5"><div class="spinner-border text-secondary" role="status"></div></div>');
                    $('#miniCartBody').load('/Cart/MiniCart');
                });
            }
        });

        // Hàm gọi AJAX thêm vào giỏ hàng và mở Mini Cart
        function addToCartAjax(productId, quantity) {
            // Nếu không có quantity truyền vào rõ ràng, thử lấy từ ô input số lượng trên trang
            if (quantity === undefined || quantity === null || quantity === 1) {
                var qtyInput = document.getElementById('quantity-' + productId) || document.querySelector('input[name="quantity"]');
                if (qtyInput) {
                    var inputVal = parseInt(qtyInput.value);
                    if (!isNaN(inputVal) && inputVal > 0) {
                        quantity = inputVal;
                    } else {
                        quantity = 1;
                    }
                } else {
                    quantity = 1;
                }
            }

            $.post('/Cart/AddAjax', { id: productId, quantity: quantity })
                .done(function (data, textStatus, xhr) {
                    // Cập nhật nội dung HTML mới
                    $('#miniCartBody').html(data);
                    
                    // Mở Offcanvas
                    var offcanvasElement = document.getElementById('offcanvasCart');
                    var bsOffcanvas = bootstrap.Offcanvas.getOrCreateInstance(offcanvasElement);
                    bsOffcanvas.show();
                    
                    var warningMsg = xhr.getResponseHeader('X-Warning-Message');
                    if (warningMsg) {
                        toastr.warning(decodeURIComponent(warningMsg));
                    } else {
                        toastr.success('Đã thêm sản phẩm vào giỏ hàng!');
                    }
                })
                .fail(function (xhr) {
                    if(xhr.status === 401) toastr.error('Vui lòng đăng nhập để thêm sản phẩm.');
                else if(xhr.status === 400) toastr.error(xhr.responseText);
                    else toastr.error('Có lỗi xảy ra, vui lòng thử lại.');
                });
        }

        // Hiệu ứng thanh điều hướng khi cuộn trang
        window.addEventListener('scroll', function () {
            var navbar = document.querySelector('.navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('navbar-scrolled');
            } else {
                navbar.classList.remove('navbar-scrolled');
            }
        });

        // Hiển thị và xử lý sự kiện click cho nút Back to Top
        var backToTopBtn = document.getElementById('backToTop');
        window.addEventListener('scroll', function () {
            if (window.scrollY > 300) {
                backToTopBtn.classList.add('show');
            } else {
                backToTopBtn.classList.remove('show');
            }
        });
        backToTopBtn.addEventListener('click', function () {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
