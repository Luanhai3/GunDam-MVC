@model GunDammvc.Models.ShoppingCart

@if (Model == null || !Model.CartItems.Any())
{
    <div class="p-5 text-center bg-white h-100 d-flex flex-column justify-content-center">
        <i class="bi bi-cart3 text-muted mb-3 d-block" style="font-size: 3rem;"></i>
        <p class="text-muted fs-5">Giỏ hàng của bạn đang trống.</p>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-luxury mt-3">Mua sắm ngay</a>
    </div>
}
else
{
    <div class="d-flex flex-column h-100">
        <!-- Product List -->
        <div class="flex-grow-1 overflow-auto p-4 bg-white">
            @foreach (var item in Model.CartItems)
            {
                <div class="d-flex mb-3 border-bottom pb-3">
                    <img src="@(string.IsNullOrEmpty(item.Product.ImageUrl) ? $"https://via.placeholder.com/70/FDFBF7/B89B5E?text={item.Product.Grade}" : item.Product.ImageUrl)" alt="@item.Product.Name" class="object-fit-cover border" style="width: 70px; height: 70px; border-radius: 2px;" />
                    <div class="ms-3 flex-grow-1">
                        <h6 class="mb-1 font-serif text-truncate" style="max-width: 170px;" title="@item.Product.Name">@item.Product.Name</h6>
                        <div class="text-muted small mb-1 text-uppercase" style="letter-spacing: 1px; font-size: 0.7rem;">Grade: @item.Product.Grade</div>
                        <div class="text-muted small">@item.Product.Price.ToString("N0") đ</div>
                        
                        <div class="d-flex align-items-center mt-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary px-2 py-0 shadow-none rounded-0" onclick="updateMiniCart(@item.Id, @(item.Quantity - 1))">-</button>
                            <span class="mx-2 small fw-bold">@item.Quantity</span>
                            <button type="button" class="btn btn-sm btn-outline-secondary px-2 py-0 shadow-none rounded-0" onclick="updateMiniCart(@item.Id, @(item.Quantity + 1))">+</button>
                        </div>
                    </div>
                    <div class="ms-2 text-end d-flex flex-column justify-content-between">
                        <button type="button" class="btn btn-link text-muted p-0 border-0 shadow-none text-end" title="Xóa" onclick="updateMiniCart(@item.Id, 0)"><i class="bi bi-x-lg fs-5"></i></button>
                        <div class="fw-bold mt-2" style="font-size: 0.95rem; color: var(--luxury-gold);">@((item.Product.Price * item.Quantity).ToString("N0")) đ</div>
                    </div>
                </div>
            }
        </div>
        
        <!-- Footer Actions -->
        <div class="p-4 bg-white border-top mt-auto">
            <div class="d-flex justify-content-between mb-3 align-items-center">
                <span class="text-muted text-uppercase small" style="letter-spacing: 1px;">Tổng cộng:</span>
                <span class="font-serif fw-bold text-dark fs-5" style="color: #c4a76a !important;">@Model.CartItems.Sum(i => i.Product.Price * i.Quantity).ToString("N0") VNĐ</span>
            </div>
            <div class="d-grid gap-2">
                <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-luxury">Xem Giỏ Hàng Chi Tiết</a>
                <a asp-controller="Cart" asp-action="Checkout" class="btn btn-luxury">Thanh Toán Ngay</a>
            </div>
        </div>
    </div>
}

<script>
    // Cập nhật badge giỏ hàng trên Navbar mà không cần reload
    (function() {
        var cartBadge = document.querySelector('a[href="#offcanvasCart"] .badge');
        if (cartBadge) {
            cartBadge.innerText = '@(Model?.CartItems.Sum(i => i.Quantity) ?? 0)';
        }
    })();

    // Hàm gọi AJAX cập nhật số lượng
    if (typeof window.updateMiniCart === 'undefined') {
        window.updateMiniCart = function(cartItemId, quantity) {
            $('#miniCartBody').html('<div class="d-flex justify-content-center mt-5"><div class="spinner-border text-secondary" role="status"></div></div>');
            $.post('/Cart/UpdateMiniCartQuantity', { cartItemId: cartItemId, quantity: quantity }, function (data) {
                $('#miniCartBody').html(data);
            });
        };
    }
</script>