@model IEnumerable<GunDammvc.Models.PointHistory>
@{
    ViewData["Title"] = "Lịch Sử Điểm Thưởng";
}

<style>
    .point-card {
        background-color: #fff;
        transition: all 0.3s ease;
        border: 1px solid var(--border-color);
    }
    .point-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
        border-color: var(--luxury-gold);
    }
    .icon-box {
        width: 55px;
        height: 55px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        flex-shrink: 0;
    }
</style>

<div class="container py-5 fade-in-up" style="min-height: 70vh;">
    <div class="text-center mb-5">
        <h1 class="font-serif fw-bold text-uppercase" style="letter-spacing: 2px;">Lịch Sử Điểm Thưởng</h1>
        <div style="width: 60px; height: 2px; background-color: var(--luxury-gold); margin: 15px auto;"></div>
        <div class="mt-4 d-flex flex-wrap justify-content-center align-items-center gap-4 gap-md-5">
            <div class="text-center">
                <span class="text-muted text-uppercase" style="letter-spacing: 1px; font-size: 0.85rem;">Hạng Thành Viên</span>
                <div class="fw-bold mt-1 font-serif" style="font-size: 2.5rem; color: var(--text-primary);">@ViewBag.MembershipTier</div>
            </div>
            <div class="border-start d-none d-md-block" style="height: 50px; border-color: var(--border-color) !important;"></div>
            <div class="text-center">
                <span class="text-muted text-uppercase" style="letter-spacing: 1px; font-size: 0.85rem;">Điểm Hiện Tại Của Bạn</span>
                <div class="fw-bold mt-1 font-serif" style="font-size: 2.5rem; color: var(--luxury-gold);">@ViewBag.CurrentPoints</div>
            </div>
        </div>
    </div>

    <div class="bg-white p-4 p-md-5 border shadow-sm" style="border-radius: 2px; max-width: 800px; margin: 0 auto;">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-stars" style="font-size: 50px; color: var(--border-color);"></i>
                <p class="text-muted mt-3">Bạn chưa có giao dịch điểm thưởng nào.</p>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-luxury mt-2">Bắt Đầu Mua Sắm</a>
            </div>
        }
        else
        {
            <div class="point-history-list">
                @foreach (var item in Model)
                {
                    <div class="point-card d-flex align-items-center justify-content-between p-3 p-md-4 mb-3 rounded shadow-sm">
                        <div class="d-flex align-items-center gap-3 gap-md-4">
                            @if (item.PointsChanged > 0)
                            {
                                <div class="icon-box" style="background-color: rgba(184, 155, 94, 0.1); color: var(--luxury-gold);">
                                    <i class="bi bi-stars fs-3"></i>
                                </div>
                            }
                            else
                            {
                                <div class="icon-box" style="background-color: rgba(220, 53, 69, 0.1); color: #dc3545;">
                                    <i class="bi bi-coin fs-3"></i>
                                </div>
                            }
                            <div>
                                <h6 class="mb-1 fw-bold text-dark font-serif" style="font-size: 1.15rem;">@item.Reason</h6>
                                <small class="text-muted"><i class="bi bi-clock me-1"></i> @item.CreatedAt.ToString("dd/MM/yyyy - HH:mm")</small>
                            </div>
                        </div>
                        <div class="text-end ms-3">
                            @if (item.PointsChanged > 0)
                            {
                                <span class="fw-bold fs-4" style="color: var(--luxury-gold);">+@item.PointsChanged</span>
                            }
                            else
                            {
                                <span class="fw-bold fs-4 text-danger">@item.PointsChanged</span>
                            }
                            <div class="small text-muted text-uppercase mt-1" style="letter-spacing: 1px; font-size: 0.75rem;">Điểm</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>