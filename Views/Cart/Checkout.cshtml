@model GunDammvc.Models.ShoppingCart
@{
    ViewData["Title"] = "Thanh Toán";
}

<style>
    .checkout-wrapper {
        max-width: 1000px;
        margin: 0 auto;
    }
    .form-control-checkout {
        border: 1px solid var(--border-color);
        border-radius: 2px;
        padding: 12px 15px;
        background: #fafafa;
    }
    .form-control-checkout:focus {
        border-color: var(--luxury-gold);
        background: #fff;
        box-shadow: none;
    }
    .summary-item {
        border-bottom: 1px dashed var(--border-color);
        padding: 15px 0;
    }
    .summary-item:last-child {
        border-bottom: none;
    }
</style>

<div class="container py-5 checkout-wrapper fade-in-up">
    <div class="text-center mb-5">
        <h2 class="font-serif fw-bold text-uppercase" style="letter-spacing: 2px;">@ViewData["Title"]</h2>
        <div style="width: 60px; height: 2px; background-color: var(--luxury-gold); margin: 15px auto;"></div>
    </div>

    <div class="row g-5">

        <!-- FORM -->
        <div class="col-lg-7">
            <div class="bg-white p-4 p-md-5 border shadow-sm" style="border-radius: 2px;">
                <h5 class="font-serif fw-bold mb-4 text-uppercase" style="letter-spacing: 1px;">Thông Tin Giao Hàng</h5>
                <form asp-action="PlaceOrder" method="post">

                    <input name="FullName" class="form-control form-control-checkout shadow-none mb-3" placeholder="Họ và Tên" required />
                    <input name="PhoneNumber" class="form-control form-control-checkout shadow-none mb-3" placeholder="Số điện thoại" required />
                    <textarea name="Address" class="form-control form-control-checkout shadow-none mb-4" placeholder="Địa chỉ giao hàng chi tiết" rows="3" required></textarea>

                    <h5 class="font-serif fw-bold mb-3 mt-4 text-uppercase" style="letter-spacing: 1px;">Phương Thức Thanh Toán</h5>
                    <div class="form-check mb-2">
                        <input class="form-check-input shadow-none" type="radio" name="PaymentMethod" id="payCOD" value="COD" checked />
                        <label class="form-check-label" for="payCOD">Thanh toán khi nhận hàng (COD)</label>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input shadow-none" type="radio" name="PaymentMethod" id="payBank" value="BankTransfer" />
                        <label class="form-check-label" for="payBank">Chuyển khoản ngân hàng</label>
                    </div>

                    <div id="bank-info-box" class="alert alert-info border-0 rounded-0 mb-4" style="display:none; background-color: #f8f9fa; border-left: 4px solid var(--luxury-gold) !important;">
                        <i class="bi bi-qr-code-scan me-2"></i><strong>Thanh toán qua chuyển khoản:</strong><br/>
                        <span class="small text-muted mt-1 d-block">Mã QR và thông tin chuyển khoản chính xác sẽ được hiển thị ở bước tiếp theo sau khi bạn nhấn "Xác Nhận Đặt Hàng". Đơn hàng sẽ được xử lý ngay sau khi hệ thống nhận được thanh toán.</span>
                    </div>

                    <hr class="my-4" />
                    
                    <h6 class="fw-bold mb-3">Sử dụng điểm thưởng</h6>
                    <div class="alert alert-light border mb-3 p-3" style="border-radius: 4px;">
                        <h6 class="fw-bold mb-2" style="font-size: 0.9rem; color: var(--text-primary);"><i class="bi bi-info-circle me-2"></i>Quy tắc tích & sử dụng điểm:</h6>
                        <ul class="mb-0 small text-muted ps-3" style="line-height: 1.6;">
                            <li class="mb-1"><strong>Tích điểm:</strong> Mỗi <strong>20.000 VNĐ</strong> thanh toán thành công = <strong>1 Điểm</strong>.</li>
                            <li><strong>Sử dụng:</strong> Quy đổi <strong>1 Điểm</strong> = <strong>1.000 VNĐ</strong> giảm giá cho đơn hàng.</li>
                        </ul>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small">Bạn đang có: <strong style="color: var(--luxury-gold);">@ViewBag.AvailablePoints Điểm</strong></label>
                        <div class="input-group">
                            <input type="number" id="UsePoints" name="UsePoints" class="form-control form-control-checkout shadow-none border-end-0" placeholder="Nhập số điểm muốn sử dụng" min="0" max="@ViewBag.AvailablePoints" value="0" />
                            <span class="input-group-text bg-white border-start-0" style="border-color: var(--border-color); color: var(--luxury-gold);">Điểm</span>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <h6 class="fw-bold mb-3">Mã Giảm Giá (Coupon)</h6>
                    <div class="mb-3">
                        <div class="input-group">
                            <input type="text" id="CouponCode" name="CouponCode" class="form-control form-control-checkout shadow-none border-end-0" placeholder="Nhập mã (VD: GUNDAM50K)" />
                            <button type="button" id="btnApplyCoupon" class="btn btn-luxury border-start-0 py-2 px-4" style="border-radius: 0 2px 2px 0;">Áp Dụng</button>
                        </div>
                        <small id="couponMessage" class="mt-1 d-none"></small>
                    </div>

                    <button class="btn btn-luxury py-3 mt-4 w-100 text-uppercase fw-bold" style="letter-spacing: 1px;">Xác Nhận Đặt Hàng</button>
                </form>
            </div>
        </div>

        <!-- SUMMARY -->
        <div class="col-lg-5">
            <div class="bg-white p-4 p-md-5 border shadow-sm sticky-top" style="border-radius: 2px; top: 100px;">
                <h5 class="font-serif fw-bold mb-4 text-uppercase" style="letter-spacing: 1px;">Đơn Hàng Của Bạn</h5>

                @if (Model?.CartItems != null)
                {
                    decimal total = 0;

                    foreach (var item in Model.CartItems)
                    {
                        decimal itemTotal = item.Product.Price * item.Quantity;
                        total += itemTotal;

                        <div class="summary-item d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-3">
                                <div class="position-relative">
                                    <img src="@(string.IsNullOrEmpty(item.Product.ImageUrl) ? "https://via.placeholder.com/60" : item.Product.ImageUrl)" alt="@item.Product.Name" style="width: 60px; height: 60px; object-fit: cover; border-radius: 2px; border: 1px solid var(--border-color);" />
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark" style="font-size: 0.7rem;">@item.Quantity</span>
                                </div>
                                <span class="fw-medium text-dark" style="font-size: 0.95rem;">@item.Product.Name</span>
                            </div>
                            <span class="fw-bold text-dark">@itemTotal.ToString("N0") đ</span>
                        </div>
                    }

                    @* FIX CHUẨN *@
                    decimal tierDiscountRate = 0m;
                    if (ViewBag.TierDiscountRate != null)
                    {
                        tierDiscountRate = Convert.ToDecimal(ViewBag.TierDiscountRate);
                    }

                    decimal discount = total * tierDiscountRate;
                    decimal finalTotal = total - discount;

                    <hr class="my-4" />

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tạm tính</span>
                        <span class="fw-medium">@total.ToString("N0") đ</span>
                    </div>

                    @if (discount > 0)
                    {
                        <div class="d-flex justify-content-between mb-2 text-success">
                            <span>Ưu đãi hạng @ViewBag.MembershipTier</span>
                            <span>-@discount.ToString("N0") đ</span>
                        </div>
                    }

                    <div id="points-discount-row" class="d-flex justify-content-between mb-2 text-success" style="display: none !important;">
                        <span>Sử dụng điểm</span>
                        <span>-<span id="points-discount-amount">0</span> đ</span>
                    </div>

                    <div id="coupon-discount-row" class="d-flex justify-content-between mb-2 text-success" style="display: none !important;">
                        <span>Mã giảm giá</span>
                        <span>-<span id="coupon-discount-amount">0</span> đ</span>
                    </div>

                    <div id="shipping-fee-row" class="d-flex justify-content-between mb-2 text-danger" style="display: none !important;">
                        <span>Phí vận chuyển</span>
                        <span>+<span id="shipping-fee-amount">0</span> đ</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                        <strong class="text-uppercase" style="letter-spacing: 1px;">Tổng cộng</strong>
                        <strong class="fs-4" style="color: var(--luxury-gold);"><span id="final-total" data-base-total="@finalTotal">@finalTotal.ToString("N0")</span> đ</strong>
                    </div>
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    const radios = document.querySelectorAll('input[name="PaymentMethod"]');
    const bankBox = document.getElementById('bank-info-box');

    radios.forEach(r => {
        r.addEventListener('change', () => {
            bankBox.style.display =
                document.querySelector('input[value="BankTransfer"]').checked
                    ? 'block'
                    : 'none';
        });
    });

    // Logic tính điểm thưởng trực tiếp
    const usePointsInput = document.getElementById('UsePoints');
    const addressInput = document.querySelector('textarea[name="Address"]');
    const pointsDiscountRow = document.getElementById('points-discount-row');
    const pointsDiscountAmount = document.getElementById('points-discount-amount');
    const couponInput = document.getElementById('CouponCode');
    const btnApplyCoupon = document.getElementById('btnApplyCoupon');
    const couponMessage = document.getElementById('couponMessage');
    const couponDiscountRow = document.getElementById('coupon-discount-row');
    const couponDiscountAmount = document.getElementById('coupon-discount-amount');
    const shippingFeeRow = document.getElementById('shipping-fee-row');
    const shippingFeeAmount = document.getElementById('shipping-fee-amount');
    const finalTotalElement = document.getElementById('final-total');
    let currentCouponDiscount = 0;

    if (usePointsInput && finalTotalElement && addressInput) {
        // Lấy tổng tiền cơ sở (đã trừ discount hạng thành viên)
        const baseTotal = parseFloat(finalTotalElement.getAttribute('data-base-total')) || 0;
        
        function calculateTotal() {
            let points = parseInt(usePointsInput.value) || 0;
            const maxPoints = parseInt(usePointsInput.getAttribute('max')) || 0;
            
            // Giới hạn số điểm nhập vào không được vượt quá số điểm đang có
            if (points < 0) points = 0;
            if (points > maxPoints) points = maxPoints;
            usePointsInput.value = points; // Cập nhật lại giá trị trên ô input nếu bị quá giới hạn

            // Tính toán số tiền được giảm (1 điểm = 1000đ)
            let pointsDiscount = points * 1000;
            
            // Hiển thị phần trừ tiền do dùng điểm
            if (points > 0) {
                pointsDiscountRow.style.setProperty('display', 'flex', 'important');
                pointsDiscountAmount.textContent = pointsDiscount.toLocaleString('vi-VN');
            } else {
                pointsDiscountRow.style.setProperty('display', 'none', 'important');
            }

            if (currentCouponDiscount > 0) {
                couponDiscountRow.style.setProperty('display', 'flex', 'important');
                couponDiscountAmount.textContent = currentCouponDiscount.toLocaleString('vi-VN');
            } else {
                couponDiscountRow.style.setProperty('display', 'none', 'important');
            }

            // Tính phí vận chuyển (Trung tâm Vũng Tàu)
            let currentShippingFee = 0;
            const address = addressInput.value.toLowerCase();
            if (!address.trim()) {
                currentShippingFee = 0;
            } else if (address.includes('vũng tàu') || address.includes('vung tau')) {
                currentShippingFee = 20000; // Nội thành Vũng Tàu
            } else {
                currentShippingFee = 40000; // Ngoại thành
            }

            if (currentShippingFee > 0) {
                shippingFeeRow.style.setProperty('display', 'flex', 'important');
                shippingFeeAmount.textContent = currentShippingFee.toLocaleString('vi-VN');
            } else {
                shippingFeeRow.style.setProperty('display', 'none', 'important');
            }

            // Cập nhật lại tổng tiền cuối cùng
            let newTotal = baseTotal - pointsDiscount - currentCouponDiscount + currentShippingFee;
            if (newTotal < 0) newTotal = 0; // Đảm bảo tổng tiền không bị âm
            
            finalTotalElement.textContent = newTotal.toLocaleString('vi-VN');
        }

        if (btnApplyCoupon) {
            btnApplyCoupon.addEventListener('click', async function() {
                const code = couponInput.value.trim().toUpperCase();
                if (code === '') {
                    currentCouponDiscount = 0;
                    couponMessage.className = 'd-none';
                    calculateTotal();
                    return;
                }

                try {
                    const response = await fetch(`/Cart/CheckCoupon?code=${code}`);
                    const result = await response.json();
                    
                    if (result.success) {
                        currentCouponDiscount = result.discountAmount;
                        couponMessage.textContent = result.message;
                        couponMessage.className = 'text-success mt-1 d-block small fw-bold';
                    } else {
                        currentCouponDiscount = 0;
                        couponMessage.textContent = result.message;
                        couponMessage.className = 'text-danger mt-1 d-block small';
                    }
                } catch (error) {
                    currentCouponDiscount = 0;
                    couponMessage.textContent = 'Lỗi kết nối khi kiểm tra mã.';
                    couponMessage.className = 'text-danger mt-1 d-block small';
                }
                calculateTotal();
            });
        }

        usePointsInput.addEventListener('input', calculateTotal);
        addressInput.addEventListener('input', calculateTotal);
        
        // Gọi 1 lần lúc mới load form để tính phí ship nếu trình duyệt tự điền địa chỉ
        calculateTotal();
    }
});
</script>
}