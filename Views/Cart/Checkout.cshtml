@{
    ViewData["Title"] = "Thanh Toán";
}

<style>
    .checkout-wrapper {
        max-width: 1000px;
        margin: 0 auto;
    }
    .form-control-checkout {
        border: 1px solid var(--border-color);
        border-radius: 2px;
        padding: 12px 15px;
        background: #fafafa;
    }
    .form-control-checkout:focus {
        background: #fff;
        border-color: var(--luxury-gold);
        box-shadow: none;
    }
</style>

<div class="container py-5 checkout-wrapper fade-in-up">
    <h2 class="serif mb-4 text-center">Xác Nhận Đặt Hàng</h2>

    <div class="row g-5">
        <div class="col-lg-7">
            <div class="bg-white p-5 shadow-sm border" style="border-radius: 2px;">
                <h4 class="font-serif mb-4 pb-3 border-bottom">Thông Tin Giao Hàng</h4>
                <form asp-action="PlaceOrder" method="post">
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase" style="letter-spacing: 1px;">Người nhận</label>
                        <input type="text" name="FullName" class="form-control form-control-checkout shadow-none" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase" style="letter-spacing: 1px;">Số điện thoại</label>
                        <input type="text" name="PhoneNumber" class="form-control form-control-checkout shadow-none" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small text-uppercase" style="letter-spacing: 1px;">Địa chỉ</label>
                        <textarea name="Address" class="form-control form-control-checkout shadow-none" rows="3" required></textarea>
                    </div>
                    
                    <h4 class="font-serif mb-4 pb-3 border-bottom mt-5">Phương Thức Thanh Toán</h4>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="PaymentMethod" id="cod" value="COD" checked>
                        <label class="form-check-label ms-2" for="cod">Thanh toán khi nhận hàng (COD)</label>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="radio" name="PaymentMethod" id="bank" value="BankTransfer">
                        <label class="form-check-label ms-2" for="bank">Chuyển khoản qua ngân hàng</label>
                    </div>
                    
                    <!-- Box thông tin ngân hàng & QR Code (Ẩn mặc định) -->
                    <div id="bank-info-box" class="mb-4 p-4 border fade-in-up" style="display: none; border-radius: 2px; background-color: var(--bg-color);">
                        <div class="d-flex flex-column flex-sm-row align-items-center gap-4">
                            <img src="https://img.vietqr.io/image/MB-0348699436-compact2.png?accountName=HOANG%20NGUYEN%20THIEN%20LUAN" alt="QR Code MB Bank" class="border shadow-sm bg-white p-2" style="width: 140px; height: 140px; border-radius: 2px;" />
                            <div>
                                <h6 class="font-serif mb-3 text-uppercase" style="color: var(--luxury-gold); letter-spacing: 1px;">Thông tin chuyển khoản</h6>
                                <p class="mb-1 text-muted small text-uppercase" style="letter-spacing: 1px;">Ngân hàng: <strong class="text-dark">MB Bank</strong></p>
                                <p class="mb-1 text-muted small text-uppercase" style="letter-spacing: 1px;">Chủ tài khoản: <strong class="text-dark">HOANG NGUYEN THIEN LUAN</strong></p>
                                <p class="mb-2 text-muted small text-uppercase" style="letter-spacing: 1px;">Số tài khoản: <strong class="text-dark fs-6">0348699436</strong></p>
                                <p class="mb-0 small text-muted" style="font-style: italic;">* Vui lòng ghi chú "SĐT hoặc Tên đặt hàng" khi chuyển khoản.</p>
                            </div>
                        </div>
                    </div>

                    <div class="form-check mb-4">
                        <input class="form-check-input" type="radio" name="PaymentMethod" id="vnpay" value="VNPay">
                        <label class="form-check-label ms-2" for="vnpay">
                            <img src="https://vnpay.vn/s1/statics.vnpay.vn/2023/9/06ncktiwd6dc1694418189687.png" alt="VNPay" height="24" class="me-2" />
                            Thanh toán qua VNPay
                        </label>
                    </div>

                    <button type="submit" class="btn btn-luxury w-100 py-3 mt-4">Hoàn Tất Đặt Hàng</button>
                </form>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="bg-white p-5 border shadow-sm" style="border-radius: 2px;">
                <h4 class="font-serif mb-4 pb-3 border-bottom">Tóm Tắt Đơn Hàng</h4>
                @if (ViewBag.CartItems != null)
                {
                    decimal total = 0;
                    foreach (var item in ViewBag.CartItems)
                    {
                        total += item.Product.Price * item.Quantity;
                        <div class="d-flex justify-content-between mb-3 pb-3 border-bottom">
                            <div>
                                <h6 class="mb-1 font-serif">@item.Product.Name</h6>
                                <small class="text-muted text-uppercase" style="letter-spacing: 1px; font-size: 0.75rem;">SL: @item.Quantity</small>
                            </div>
                            <span class="fw-bold" style="color: var(--luxury-gold);">@((item.Product.Price * item.Quantity).ToString("N0")) đ</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between mt-4 pt-2">
                        <h6 class="text-uppercase text-muted" style="letter-spacing: 1px;">Tổng cộng:</h6>
                        <h4 class="font-serif fw-bold mb-0" style="color: var(--luxury-gold);">@total.ToString("N0") VNĐ</h4>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const radios = document.querySelectorAll('input[name="PaymentMethod"]');
            const bankBox = document.getElementById('bank-info-box');

            function toggleBankBox() {
                const selected = document.querySelector('input[name="PaymentMethod"]:checked');
                if (selected && selected.value === 'BankTransfer') {
                    bankBox.style.display = 'block';
                } else {
                    bankBox.style.display = 'none';
                }
            }

            radios.forEach(radio => {
                radio.addEventListener('change', toggleBankBox);
            });
        });
    </script>
}