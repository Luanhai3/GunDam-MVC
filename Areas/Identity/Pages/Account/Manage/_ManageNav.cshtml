@using GunDammvc.Models
@inject SignInManager<ApplicationUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}
<ul class="nav nav-pills flex-column bg-white border shadow-sm p-3" style="border-radius: 2px;">
    <li class="nav-item mb-2">
        <a class="nav-link @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index" style="color: var(--text-primary);">
            <i class="bi bi-person me-2"></i> Hồ Sơ
        </a>
    </li>
    <li class="nav-item mb-2">
        <a class="nav-link @ManageNavPages.EmailNavClass(ViewContext)" id="email" asp-page="./Email" style="color: var(--text-primary);">
            <i class="bi bi-envelope me-2"></i> Email
        </a>
    </li>
    <li class="nav-item mb-2">
        <a class="nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword" style="color: var(--text-primary);">
            <i class="bi bi-key me-2"></i> Mật Khẩu
        </a>
    </li>
    @if (hasExternalLogins)
    {
        <li id="external-logins" class="nav-item mb-2">
            <a id="external-login" class="nav-link @ManageNavPages.ExternalLoginsNavClass(ViewContext)" asp-page="./ExternalLogins" style="color: var(--text-primary);">
                <i class="bi bi-box-arrow-in-right me-2"></i> Liên kết tài khoản
            </a>
        </li>
    }
    <li class="nav-item">
        <a class="nav-link @ManageNavPages.PersonalDataNavClass(ViewContext)" id="personal-data" asp-page="./PersonalData" style="color: var(--text-primary);">
            <i class="bi bi-shield-lock me-2"></i> Dữ Liệu Cá Nhân
        </a>
    </li>
</ul>
<style>
    .nav-pills .nav-link.active {
        background-color: var(--luxury-gold) !important;
        color: #fff !important;
    }
    .nav-pills .nav-link:hover:not(.active) {
        background-color: #f8f9fa;
        color: var(--luxury-gold) !important;
    }
</style>
